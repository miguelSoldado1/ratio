{
  "name": "ratio-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @ratio/web dev",
    "dev:admin": "pnpm --filter @ratio/admin dev",
    "dev:all": "pnpm --parallel --filter @ratio/web --filter @ratio/admin dev",
    "dev:cf": "pnpm --filter @ratio/web dev:cf",
    "dev:admin:cf": "pnpm --filter @ratio/admin dev:cf",
    "build": "pnpm --filter @ratio/web build",
    "build:admin": "pnpm --filter @ratio/admin build",
    "build:all": "pnpm --filter @ratio/database typecheck && pnpm --filter @ratio/web --filter @ratio/admin build",
    "deploy": "pnpm --filter @ratio/web deploy",
    "deploy:admin": "pnpm --filter @ratio/admin deploy",
    "cf-typegen": "pnpm --filter @ratio/web cf-typegen",
    "cf-typegen:admin": "pnpm --filter @ratio/admin cf-typegen",
    "preview": "pnpm --filter @ratio/web preview",
    "seed": "node scripts/seed.mjs",
    "test": "pnpm --filter @ratio/web test",
    "test:admin": "pnpm --filter @ratio/admin test",
    "test:all": "pnpm --filter @ratio/web test && pnpm --filter @ratio/admin test",
    "test:db": "pnpm --filter @ratio/web test:db",
    "test:unit": "pnpm --filter @ratio/web test:unit",
    "test:watch": "pnpm --filter @ratio/web test:watch",
    "lint": "pnpm run check",
    "format": "ultracite fix",
    "check": "pnpm --filter @ratio/web check",
    "check:admin": "pnpm --filter @ratio/admin check",
    "check:all": "pnpm exec ultracite check && pnpm -r typecheck",
    "typecheck": "pnpm --filter @ratio/web typecheck",
    "typecheck:admin": "pnpm --filter @ratio/admin typecheck",
    "typecheck:all": "pnpm -r typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6",
    "ultracite": "7.8.3",
    "wrangler": "^4.100.0"
  }
}
