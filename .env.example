# Required for local development and Drizzle commands.
# Deployed Cloudflare Workers use the HYPERDRIVE binding instead.
DATABASE_URL="your_database_url_here"

# Required everywhere, but should be stored as Wrangler secrets in deployed Workers.
BETTER_AUTH_SECRET="your_better_auth_secret_here"

# Required locally. In deployed Workers, this can live in wrangler.jsonc `vars`.
BETTER_AUTH_URL="http://127.0.0.1:3000"

# Required everywhere, but should be stored as Wrangler secrets in deployed Workers.
SPOTIFY_CLIENT_ID="your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret_here"

# Required everywhere, but should be stored as Wrangler secrets in deployed Workers.
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Required everywhere, but should be stored as Wrangler secrets in deployed Workers.
DISCORD_CLIENT_ID="your_discord_client_id_here"
DISCORD_CLIENT_SECRET="your_discord_client_secret_here"

# Required locally. In deployed Workers, these non-secret values can live in wrangler.jsonc `vars`.
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id_here"
CLOUDFLARE_R2_BUCKET_NAME="your_r2_bucket_name_here"
CLOUDFLARE_R2_PUBLIC_URL="https://your_public_r2_url_here"

# Required everywhere, but should be stored as Wrangler secrets in deployed Workers.
CLOUDFLARE_ACCESS_KEY_ID="your_r2_access_key_id_here"
CLOUDFLARE_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"
